{
  "name": "backend-launcher",
  "displayName": "Backend Launcher",
  "description": "Avvia e gestisci i backend di sviluppo dei tuoi progetti, in terminali VSCode veri. Legge lo stesso services.json dell'app Backend Launcher.",
  "version": "0.0.1",
  "publisher": "blauncher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Thairyne0/b-launcher.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "keywords": ["backend", "launcher", "orchestrator", "dev servers", "monorepo"],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backendLauncher",
          "title": "Backend Launcher",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "backendLauncher": [
        {
          "id": "backendLauncherServices",
          "name": "Servizi"
        }
      ]
    },
    "commands": [
      { "command": "backendLauncher.refresh", "title": "Backend Launcher: Aggiorna", "icon": "$(refresh)" },
      { "command": "backendLauncher.startService", "title": "Avvia", "icon": "$(play)" },
      { "command": "backendLauncher.stopService", "title": "Ferma", "icon": "$(debug-stop)" },
      { "command": "backendLauncher.restartService", "title": "Riavvia", "icon": "$(debug-restart)" },
      { "command": "backendLauncher.startServiceWith", "title": "Avvia con…", "icon": "$(run-all)" },
      { "command": "backendLauncher.revealTerminal", "title": "Mostra terminale", "icon": "$(terminal)" },
      { "command": "backendLauncher.startProject", "title": "Avvia progetto", "icon": "$(play)" },
      { "command": "backendLauncher.stopProject", "title": "Ferma progetto", "icon": "$(debug-stop)" },
      { "command": "backendLauncher.restartProject", "title": "Riavvia progetto", "icon": "$(debug-restart)" },
      { "command": "backendLauncher.openProjectDashboard", "title": "Apri dashboard", "icon": "$(dashboard)" },
      { "command": "backendLauncher.openProjectTerminals", "title": "Apri terminali affiancati", "icon": "$(split-horizontal)" },
      { "command": "backendLauncher.startStack", "title": "Avvia stack (app per ultima)", "icon": "$(rocket)" },
      { "command": "backendLauncher.openAppUrl", "title": "Apri nel browser", "icon": "$(globe)" },
      { "command": "backendLauncher.saveDetectedProject", "title": "Salva progetto in Backend Launcher", "icon": "$(save)" },
      { "command": "backendLauncher.startAll", "title": "Backend Launcher: Avvia tutti", "icon": "$(run-all)" },
      { "command": "backendLauncher.stopAll", "title": "Backend Launcher: Ferma tutti", "icon": "$(stop-circle)" },
      { "command": "backendLauncher.scanWorkspace", "title": "Backend Launcher: Scansiona la cartella corrente", "icon": "$(search)" }
    ],
    "menus": {
      "view/title": [
        { "command": "backendLauncher.startAll", "when": "view == backendLauncherServices", "group": "navigation@1" },
        { "command": "backendLauncher.stopAll", "when": "view == backendLauncherServices", "group": "navigation@2" },
        { "command": "backendLauncher.scanWorkspace", "when": "view == backendLauncherServices", "group": "navigation@3" },
        { "command": "backendLauncher.refresh", "when": "view == backendLauncherServices", "group": "navigation@4" }
      ],
      "view/item/context": [
        { "command": "backendLauncher.startService", "when": "view == backendLauncherServices && viewItem =~ /^service\\.stopped/", "group": "inline@1" },
        { "command": "backendLauncher.stopService", "when": "view == backendLauncherServices && viewItem =~ /^service\\.running/", "group": "inline@1" },
        { "command": "backendLauncher.restartService", "when": "view == backendLauncherServices && viewItem =~ /^service\\.running/", "group": "inline@2" },
        { "command": "backendLauncher.openAppUrl", "when": "view == backendLauncherServices && viewItem =~ /^service.*\\.url/", "group": "inline@3" },
        { "command": "backendLauncher.startServiceWith", "when": "view == backendLauncherServices && viewItem =~ /^service/", "group": "svc@1" },
        { "command": "backendLauncher.revealTerminal", "when": "view == backendLauncherServices && viewItem =~ /^service\\.running/", "group": "svc@2" },
        { "command": "backendLauncher.openProjectDashboard", "when": "view == backendLauncherServices && viewItem =~ /^(project|detected)/", "group": "inline@1" },
        { "command": "backendLauncher.startProject", "when": "view == backendLauncherServices && viewItem =~ /^(project|detected)/", "group": "inline@2" },
        { "command": "backendLauncher.stopProject", "when": "view == backendLauncherServices && viewItem =~ /^(project|detected)\\.running/", "group": "inline@3" },
        { "command": "backendLauncher.startStack", "when": "view == backendLauncherServices && viewItem =~ /^(project|detected)/", "group": "prj@1" },
        { "command": "backendLauncher.restartProject", "when": "view == backendLauncherServices && viewItem =~ /^(project|detected)\\.running/", "group": "prj@2" },
        { "command": "backendLauncher.openProjectTerminals", "when": "view == backendLauncherServices && viewItem =~ /^(project|detected)/", "group": "prj@3" },
        { "command": "backendLauncher.saveDetectedProject", "when": "view == backendLauncherServices && viewItem =~ /^detected/", "group": "prj@4" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "backendLauncherServices",
        "contents": "Nessun backend qui ancora.\n\nApri una cartella con dei progetti e scansionala, oppure configurali nell'app Backend Launcher.\n\n[$(search) Scansiona la cartella corrente](command:backendLauncher.scanWorkspace)\n[$(refresh) Aggiorna](command:backendLauncher.refresh)"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "vsce package --no-dependencies",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.30.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
